{
  "name": "@zodiacchain/backend",
  "version": "0.1.0",
  "description": "Fastify and TypeScript mock API workspace for the ZodiacChain MVP.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --import tsx --test src/app.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "tsx": "^4.22.0"
  }
}
