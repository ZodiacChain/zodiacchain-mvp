{
  "name": "zodiacchain-mvp",
  "version": "0.1.0",
  "description": "Testnet-first implementation repository for verifiable draw infrastructure.",
  "license": "MIT",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.9.2"
  },
  "workspaces": [
    "frontend",
    "backend",
    "contracts"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "check": "npm run format:check && npm run lint && npm run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
